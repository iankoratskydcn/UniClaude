{
  "name": "uniclaude-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "UniClaude Agent SDK sidecar — bridges Claude Agent SDK to Unity Editor",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js",
    "postinstall": "[ \"$(uname)\" = Darwin ] && xattr -dr com.apple.quarantine node_modules/@anthropic-ai 2>/dev/null; exit 0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
